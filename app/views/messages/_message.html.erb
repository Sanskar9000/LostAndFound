<% mine = message.sender == current_user %>
<div class="d-flex <%= mine ? 'justify-content-end' : 'justify-content-start' %> mb-3">
  <div class="p-3 rounded-4 <%= mine ? 'bg-dark text-white' : 'card card-soft border-0' %>" style="max-width: min(82%, 520px);">
    <div class="small <%= mine ? 'text-white-50' : 'text-muted' %> mb-1">
      <%= mine ? "You" : message.sender.email %>
    </div>
    <div><%= simple_format(message.body) %></div>
    <div class="small <%= mine ? 'text-white-50' : 'text-muted' %> mt-2">
      <%= message.created_at.strftime("%d %b, %I:%M %p") %>
    </div>
  </div>
</div>
