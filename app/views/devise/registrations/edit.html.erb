<div class="container py-4" style="max-width: 720px;">
  <div class="card card-soft">
    <div class="card-body p-4 p-md-5">
      <h3 class="fw-bold mb-1">Edit Account</h3>
      <div class="text-muted mb-4">Update your login and campus details.</div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="row g-3">
          <div class="col-12">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "form-control form-control-lg rounded-3" %>
          </div>

          <div class="col-md-6">
            <%= f.label :campus_id, "Campus", class: "form-label fw-semibold" %>
            <%= f.collection_select :campus_id,
              Campus.active.order(:name),
              :id,
              :name,
              { prompt: "Select campus" },
              class: "form-select form-select-lg rounded-3",
              required: true %>
          </div>

          <div class="col-md-6">
            <%= f.label :department, "Department", class: "form-label fw-semibold" %>
            <%= f.select :department,
              ["Computer Science", "IT", "Mechanical", "Civil", "Electrical", "Electronics", "Other"],
              { prompt: "Select department" },
              class: "form-select form-select-lg rounded-3",
              required: true %>
          </div>

          <div class="col-md-6">
            <%= f.label :role, "Role", class: "form-label fw-semibold" %>
            <%= f.select :role,
              [["Student", "student"], ["Faculty", "faculty"]],
              {},
              class: "form-select form-select-lg rounded-3" %>
          </div>

          <div class="col-md-6">
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="small text-muted pt-md-4">
                Waiting confirmation for <span class="fw-semibold"><%= resource.unconfirmed_email %></span>
              </div>
            <% end %>
          </div>

          <div class="col-md-6">
            <%= f.label :password, class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "new-password",
              class: "form-control form-control-lg rounded-3" %>
            <% if @minimum_password_length %>
              <div class="form-text"><%= @minimum_password_length %> characters minimum</div>
            <% end %>
          </div>

          <div class="col-md-6">
            <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "form-control form-control-lg rounded-3" %>
          </div>

          <div class="col-12">
            <%= f.label :current_password, class: "form-label fw-semibold" %>
            <%= f.password_field :current_password, autocomplete: "current-password",
              class: "form-control form-control-lg rounded-3" %>
            <div class="form-text">Enter your current password to save changes.</div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
          <%= f.submit "Update Account", class: "btn btn-dark btn-lg rounded-3" %>
          <%= link_to "Back", root_path, class: "btn btn-outline-secondary btn-lg rounded-3" %>
        </div>
      <% end %>

      <hr class="my-4">

      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
        <div>
          <div class="fw-semibold">Cancel account</div>
          <div class="small text-muted">This permanently deletes your account.</div>
        </div>
        <%= button_to "Cancel my account",
          registration_path(resource_name),
          data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
          method: :delete,
          class: "btn btn-outline-danger" %>
      </div>
    </div>
  </div>
</div>
