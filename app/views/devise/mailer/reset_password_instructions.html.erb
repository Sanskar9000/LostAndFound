<div style="background:#f4f7fb;padding:32px 16px;font-family:Arial,sans-serif;color:#0f172a;">
  <div style="max-width:560px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:24px;overflow:hidden;box-shadow:0 18px 45px rgba(15,23,42,0.08);">
    <div style="padding:28px 32px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#ffffff;">
      <div style="font-size:13px;letter-spacing:.08em;text-transform:uppercase;opacity:.7;">Campus Lost &amp; Found</div>
      <h1 style="margin:10px 0 0;font-size:28px;line-height:1.2;">Reset your password</h1>
    </div>

    <div style="padding:32px;">
      <p style="margin-top:0;font-size:15px;line-height:1.7;">Hello <strong><%= @resource.email %></strong>,</p>

      <p style="font-size:15px;line-height:1.7;color:#334155;">
        We received a request to reset the password for your Campus Lost &amp; Found account.
        Use the button below to choose a new password.
      </p>

      <div style="margin:28px 0;">
        <%= link_to "Reset Password",
          edit_password_url(@resource, reset_password_token: @token),
          style: "display:inline-block;padding:14px 22px;border-radius:14px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#ffffff;text-decoration:none;font-weight:700;" %>
      </div>

      <p style="font-size:14px;line-height:1.7;color:#475569;">
        If you didn’t request this, you can safely ignore this email. Your password will stay the same until you open the link above and save a new one.
      </p>

      <div style="margin-top:28px;padding-top:20px;border-top:1px solid #e2e8f0;font-size:13px;line-height:1.7;color:#64748b;">
        If the button doesn’t work, copy and paste this link into your browser:<br>
        <span style="word-break:break-all;"><%= edit_password_url(@resource, reset_password_token: @token) %></span>
      </div>
    </div>
  </div>
</div>
