<div class="container py-5" style="max-width: 460px;">
  <div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4 p-md-5">
      <h3 class="fw-bold mb-1">Reset your password</h3>
      <div class="text-muted mb-4">
        Enter the email linked to your account and we’ll send you a secure reset link.
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-semibold" %>
          <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "form-control form-control-lg rounded-3",
            placeholder: "you@campus.edu" %>
        </div>

        <div class="d-grid gap-2">
          <%= f.submit "Send Reset Link", class: "btn btn-dark btn-lg rounded-3" %>
          <%= link_to "Back to login", new_session_path(resource_name), class: "btn btn-outline-secondary btn-lg rounded-3" %>
        </div>
      <% end %>

      <div class="mt-4 text-center small text-muted">
        Need a new account?
        <%= link_to "Create one here", new_registration_path(resource_name), class: "text-decoration-none" %>
      </div>
    </div>
  </div>
</div>
