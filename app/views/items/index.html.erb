<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h4 class="fw-bold mb-0">Items</h4>
    <div class="text-muted small">Browse all lost and found items</div>
    <div class="mt-3">
      <%= render "status_tabs", current_status: @current_status %>
    </div>
  </div>

  <%= render "view_toggle" %>
</div>

<div class="card card-soft mb-3">
  <div class="card-body">
    <%= form_with url: items_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
      <%= hidden_field_tag :view, index_view_mode %>
      <%= hidden_field_tag :status, @current_status %>
      <div class="col-md-4">
        <label for="campus_id" class="form-label fw-semibold">Campus</label>
        <%= select_tag :campus_id,
          options_from_collection_for_select(@campuses, :id, :name, params[:campus_id]),
          include_blank: "All campuses",
          class: "form-select" %>
      </div>

      <div class="col-md-auto">
        <%= submit_tag "Filter", class: "btn btn-dark" %>
      </div>

      <% if params[:campus_id].present? %>
        <div class="col-md-auto">
          <%= link_to "Clear", items_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<div class="card card-soft">
  <div class="card-body">
    <% if @items.present? %>
      <% if index_view_mode == "list" %>
        <%= render "list", items: @items %>
      <% else %>
        <%= render "grid", items: @items %>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-5">No items found.</div>
    <% end %>
  </div>
</div>
