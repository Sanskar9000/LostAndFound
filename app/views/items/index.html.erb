<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Items</h4>
    <div class="text-muted small">Browse all lost and found items</div>
  </div>
</div>

<div class="card card-soft">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Type</th>
            <th>Title</th>
            <th>Category</th>
            <th>Location</th>
            <th>Date</th>
            <th>Posted By</th>
            <th class="text-end">Action</th>
          </tr>
        </thead>
        <tbody>
          <% @items.each do |item| %>
            <tr>
              <td>
                <% if item.item_type == "lost" %>
                  <span class="badge badge-soft-danger">Lost</span>
                <% else %>
                  <span class="badge badge-soft-success">Found</span>
                <% end %>
              </td>
              <td class="fw-semibold"><%= item.title %></td>
              <td class="text-muted"><%= item.category %></td>
              <td class="text-muted"><%= item.location %></td>
              <td class="text-muted"><%= item.found_on %></td>
              <td class="text-muted"><%= item.user&.email %></td>
              <td class="text-end">
                <%= link_to "View", item_path(item), class: "btn btn-sm btn-dark" %>
              </td>
            </tr>
          <% end %>

          <% if @items.blank? %>
            <tr>
              <td colspan="7" class="text-center text-muted py-5">
                No items found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>