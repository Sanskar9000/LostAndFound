<div class="row g-3">
  <% items.each do |item| %>
    <div class="col-sm-6 col-xl-4">
      <div class="card card-soft h-100 overflow-hidden">
        <%= image_tag item_preview_source(item), class: "card-preview border-bottom" %>
        <div class="card-body p-4 d-flex flex-column">
          <div class="d-flex gap-2 mb-3">
            <% if item.item_type == "lost" %>
              <span class="badge badge-soft-danger">Lost</span>
            <% else %>
              <span class="badge badge-soft-success">Found</span>
            <% end %>
            <span class="badge badge-soft-primary"><%= item_status_badge(item).capitalize %></span>
          </div>

          <h6 class="fw-bold mb-1"><%= item.title %></h6>
          <div class="text-muted small mb-3"><%= truncate(item.description.to_s, length: 80) %></div>

          <div class="small text-muted mb-1">Category: <span class="text-muted fw-semibold"><%= item.category %></span></div>
          <div class="small text-muted mb-1">Campus: <span class="text-muted fw-semibold"><%= item.campus&.name %></span></div>
          <div class="small text-muted mb-1">Location: <span class="text-muted fw-semibold"><%= item.location %></span></div>
          <div class="small text-muted mb-3">Posted by: <span class="text-muted fw-semibold"><%= item.user&.email %></span></div>

          <div class="mt-auto d-flex justify-content-between align-items-center">
            <div class="small text-muted"><%= item.found_on %></div>
            <div class="d-flex gap-2">
              <% if item_recovery_candidate?(item) && item.user != current_user %>
                <%= link_to "I Found This", new_item_path(type: "found", reference_item_id: item.id), class: "btn btn-sm btn-outline-dark" %>
              <% end %>
              <%= link_to "View", item_path(item), class: "btn btn-sm btn-dark" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
