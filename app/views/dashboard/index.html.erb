<div class="row g-3">
  <div class="col-lg-4">
    <div class="card card-soft p-4">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <div class="text-muted small">Total Items</div>
          <div class="display-6 fw-bold"><%= Item.count %></div>
        </div>
        <span class="badge badge-soft-primary px-3 py-2">Live</span>
      </div>
      <hr>
      <div class="d-flex justify-content-between small text-muted">
        <div>Lost: <span class="fw-semibold text-dark"><%= Item.where(item_type: "lost").count %></span></div>
        <div>Found: <span class="fw-semibold text-dark"><%= Item.where(item_type: "found").count %></span></div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card card-soft p-4">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <div class="text-muted small">Pending Claims</div>
          <div class="display-6 fw-bold"><%= Claim.where(status: "pending").count %></div>
        </div>
        <span class="badge badge-soft-danger px-3 py-2">Action</span>
      </div>
      <hr>
      <div class="small text-muted">
        Claims help confirm ownership using claim notes.
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card card-soft p-4">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <div class="text-muted small">Your Posts</div>
          <div class="display-6 fw-bold"><%= Item.where(user_id: current_user.id).count %></div>
        </div>
        <span class="badge badge-soft-success px-3 py-2">You</span>
      </div>
      <hr>
      <div class="small text-muted">
        You can post lost/found items and track claim requests.
      </div>
    </div>
  </div>
</div>

<div class="card card-soft mt-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h5 class="fw-bold mb-0">Latest Items</h5>
        <div class="small text-muted">Recently posted lost and found items</div>
      </div>
      <a href="<%= items_path %>" class="btn btn-sm btn-outline-dark">View All</a>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Type</th>
            <th>Title</th>
            <th>Category</th>
            <th>Location</th>
            <th>Date</th>
            <th class="text-end">Action</th>
          </tr>
        </thead>
        <tbody>
          <% Item.order(created_at: :desc).limit(8).each do |item| %>
            <tr>
              <td>
                <% if item.item_type == "lost" %>
                  <span class="badge badge-soft-danger">Lost</span>
                <% else %>
                  <span class="badge badge-soft-success">Found</span>
                <% end %>
              </td>
              <td class="fw-semibold"><%= item.title %></td>
              <td class="text-muted"><%= item.category %></td>
              <td class="text-muted"><%= item.location %></td>
              <td class="text-muted"><%= item.found_on %></td>
              <td class="text-end">
                <a class="btn btn-sm btn-dark" href="<%= item_path(item) %>">View</a>
              </td>
            </tr>
          <% end %>

          <% if Item.count == 0 %>
            <tr>
              <td colspan="6" class="text-center text-muted py-5">
                No items posted yet. Use “Post Lost” or “Post Found” to add one.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>