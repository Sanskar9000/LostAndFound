<div style="background:#f4f7fb;padding:32px 16px;font-family:Arial,sans-serif;color:#0f172a;">
  <div style="max-width:560px;margin:0 auto;background:#ffffff;border:1px solid #e5e7eb;border-radius:24px;overflow:hidden;box-shadow:0 18px 45px rgba(15,23,42,0.08);">
    <div style="padding:28px 32px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#ffffff;">
      <div style="font-size:13px;letter-spacing:.08em;text-transform:uppercase;opacity:.7;">Campus Lost &amp; Found</div>
      <h1 style="margin:10px 0 0;font-size:28px;line-height:1.2;">Someone may have found your item</h1>
    </div>

    <div style="padding:32px;">
      <p style="margin-top:0;font-size:15px;line-height:1.7;">Hello <strong><%= @lost_item.user.email %></strong>,</p>

      <p style="font-size:15px;line-height:1.7;color:#334155;">
        A user has added a found item in the app that appears to match your lost item report for
        <strong><%= @lost_item.title %></strong>.
      </p>

      <div style="margin:18px 0;padding:16px 18px;border:1px solid #e2e8f0;border-radius:16px;background:#f8fafc;">
        <div style="font-size:14px;line-height:1.7;color:#475569;">
          <strong>Found item posted by:</strong> <%= @reporter.email %><br>
          <strong>Category:</strong> <%= @found_item.category %><br>
          <strong>Location:</strong> <%= @found_item.location %><br>
          <strong>Date:</strong> <%= @found_item.found_on %>
        </div>
      </div>

      <p style="font-size:15px;line-height:1.7;color:#334155;">
        If this looks like your item, you can go directly to the claim page and submit your request.
      </p>

      <div style="margin:28px 0;">
        <%= link_to "Claim This Item",
          new_item_claim_url(@found_item),
          style: "display:inline-block;padding:14px 22px;border-radius:14px;background:linear-gradient(135deg,#0f172a,#1e293b);color:#ffffff;text-decoration:none;font-weight:700;" %>
      </div>

      <div style="margin-top:28px;padding-top:20px;border-top:1px solid #e2e8f0;font-size:13px;line-height:1.7;color:#64748b;">
        You can also review the found item first here:<br>
        <span style="word-break:break-all;"><%= item_url(@found_item) %></span>
      </div>
    </div>
  </div>
</div>
