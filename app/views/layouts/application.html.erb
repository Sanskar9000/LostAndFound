<!DOCTYPE html>
<html>
  <head>
    <title>Lost & Found</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
      :root { --sidebar-width: 260px; }

      body { background: #f6f7fb; }

      .app-shell { min-height: 100vh; }

      .sidebar {
        width: var(--sidebar-width);
        background: #111827;
        color: #fff;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }

      .sidebar .brand {
        padding: 18px 18px;
        border-bottom: 1px solid rgba(255,255,255,.08);
      }

      .sidebar .nav-link {
        color: rgba(255,255,255,.78);
        padding: 10px 14px;
        border-radius: 10px;
      }

      .sidebar .nav-link:hover {
        background: rgba(255,255,255,.08);
        color: #fff;
      }

      .sidebar .nav-link.active {
        background: rgba(99,102,241,.22);
        color: #fff;
        border: 1px solid rgba(99,102,241,.35);
      }

      .sidebar .section-title {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(255,255,255,.5);
        padding: 14px 18px 8px;
      }

      .content-wrap { flex: 1; }

      .topbar {
        background: #fff;
        border-bottom: 1px solid #e9ecef;
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .page-container { padding: 22px; }

      .card-soft {
        border: 1px solid #edf0f6;
        box-shadow: 0 10px 30px rgba(17,24,39,0.06);
        border-radius: 16px;
      }

      .badge-soft-danger { background: rgba(220,53,69,.12); color: #dc3545; }
      .badge-soft-success { background: rgba(25,135,84,.12); color: #198754; }
      .badge-soft-primary { background: rgba(13,110,253,.12); color: #0d6efd; }

      .table thead th { color: #6b7280; font-weight: 600; font-size: 13px; }
      .table td { vertical-align: middle; }

      @media (max-width: 992px) {
        .sidebar { position: fixed; left: -270px; transition: left .2s ease; z-index: 50; }
        .sidebar.show { left: 0; }
        .sidebar-backdrop { display:none; }
        .sidebar-backdrop.show {
          display:block;
          position: fixed;
          inset: 0;
          background: rgba(0,0,0,.4);
          z-index: 40;
        }
      }
    </style>
  </head>

  <body>
    <script>
      function toggleSidebar(){
        const sb = document.getElementById("appSidebar");
        const bd = document.getElementById("sidebarBackdrop");
        if(!sb || !bd) return;
        sb.classList.toggle("show");
        bd.classList.toggle("show");
      }
    </script>

    <% if user_signed_in? %>
      <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

      <div class="d-flex app-shell">
        <!-- Sidebar -->
        <aside class="sidebar" id="appSidebar">
          <div class="brand d-flex align-items-center justify-content-between">
            <div>
              <div class="fw-bold" style="font-size: 18px;">Lost & Found</div>
              <div class="small" style="color: rgba(255,255,255,.55);">Campus Portal</div>
            </div>
            <button class="btn btn-sm btn-outline-light d-lg-none" onclick="toggleSidebar()">✕</button>
          </div>

          <div class="section-title">Main</div>
          <nav class="px-3 pb-3">
            <a class="nav-link <%= current_page?(root_path) ? 'active' : '' %>" href="<%= root_path %>">
              Dashboard
            </a>

            <a class="nav-link <%= request.path.start_with?('/items') ? 'active' : '' %>" href="<%= items_path %>">
              Items
            </a>

            <a class="nav-link <%= request.path.start_with?('/claims') ? 'active' : '' %>" href="<%= claims_path %>">
              Claims
            </a>

            <% if current_user.admin? || current_user.faculty? %>
              <a class="nav-link <%= request.path.start_with?('/staff/claims') ? 'active' : '' %>" href="<%= staff_claims_path %>">
                Pending Claims
              </a>
            <% end %>

            <% if current_user.admin? %>
              <div class="section-title mt-2">Admin</div>
              <a class="nav-link" href="/admin">
                Admin Panel
              </a>
            <% end %>
          </nav>

          <div class="mt-auto px-3 pb-4">
            <div class="card card-soft p-3" style="background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.08);">
              <div class="small" style="color: rgba(255,255,255,.6);">Logged in as</div>
              <div class="fw-semibold"><%= current_user.email %></div>
              <div class="small" style="color: rgba(255,255,255,.6);"><%= current_user.role %></div>
            </div>
          </div>
        </aside>

        <!-- Main -->
        <main class="content-wrap">
          <!-- Topbar -->
          <div class="topbar">
            <div class="container-fluid">
              <div class="d-flex align-items-center justify-content-between py-3 px-2 px-md-3">
                <div class="d-flex align-items-center gap-2">
                  <button class="btn btn-outline-secondary d-lg-none" onclick="toggleSidebar()">☰</button>
                  <div>
                    <div class="fw-bold">Campus Lost & Found</div>
                    <div class="small text-muted">Track lost items, found items, and claim requests</div>
                  </div>
                </div>

                <div class="d-flex align-items-center gap-2">
                  <a class="btn btn-sm btn-outline-dark" href="<%= new_item_path(type: 'lost') %>">+ Post Lost</a>
                  <a class="btn btn-sm btn-outline-dark" href="<%= new_item_path(type: 'found') %>">+ Post Found</a>

                  <div class="dropdown">
                    <button class="btn btn-sm btn-dark dropdown-toggle" data-bs-toggle="dropdown">
                      Account
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                      <div class="px-3 py-2 small text-muted">
                        <div class="fw-semibold"><%= current_user.email %></div>
                        <div><%= current_user.role %></div>
                      </div>
                      <div class="dropdown-divider"></div>
                      <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "dropdown-item" %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Flash -->
          <div class="container-fluid">
            <div class="px-2 px-md-3 pt-3">
              <% flash.each do |type, msg| %>
                <% bs = (type.to_s == "notice") ? "success" : (type.to_s == "alert") ? "danger" : "info" %>
                <div class="alert alert-<%= bs %> alert-dismissible fade show" role="alert">
                  <%= msg %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
              <% end %>
            </div>
          </div>

          <div class="page-container">
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <!-- If not logged in, show clean centered container for Devise screens -->
      <div class="container py-5">
        <%= yield %>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>