<!DOCTYPE html>
<html>
  <head>
    <title>Lost & Found</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --sidebar-width: 270px;
        --sidebar-collapsed-width: 96px;
        --shell-bg: #f4f7fb;
        --panel-bg: rgba(255,255,255,.86);
        --panel-border: rgba(148,163,184,.18);
        --ink-900: #0f172a;
        --ink-700: #334155;
        --ink-500: #64748b;
        --accent: #0f766e;
        --accent-soft: rgba(15,118,110,.12);
        --shadow-soft: 0 18px 45px rgba(15,23,42,.08);
        --topbar-bg: linear-gradient(180deg, rgba(15,23,42,.98) 0%, rgba(15,23,42,.92) 100%);
        --topbar-border: rgba(255,255,255,.06);
        --topbar-text: #f8fafc;
        --topbar-subtext: rgba(255,255,255,.62);
        --surface-muted: #f3f4f6;
        --dropdown-bg: rgba(255,255,255,.98);
      }

      body.theme-dark {
        --shell-bg: #020617;
        --panel-bg: rgba(15,23,42,.88);
        --panel-border: rgba(148,163,184,.16);
        --ink-900: #e2e8f0;
        --ink-700: #cbd5e1;
        --ink-500: #94a3b8;
        --accent-soft: rgba(45,212,191,.16);
        --shadow-soft: 0 18px 45px rgba(2,6,23,.45);
        --topbar-bg: linear-gradient(180deg, rgba(2,6,23,.98) 0%, rgba(15,23,42,.96) 100%);
        --topbar-border: rgba(148,163,184,.12);
        --topbar-text: #f8fafc;
        --topbar-subtext: rgba(226,232,240,.72);
        --surface-muted: #0f172a;
        --dropdown-bg: rgba(15,23,42,.98);
      }

      body {
        background:
          radial-gradient(circle at top left, rgba(20,184,166,.10), transparent 28%),
          radial-gradient(circle at top right, rgba(59,130,246,.10), transparent 26%),
          linear-gradient(180deg, #f8fbff 0%, var(--shell-bg) 100%);
        color: var(--ink-900);
      }

      body,
      p,
      span,
      div,
      li,
      dt,
      dd,
      td,
      th,
      label,
      input,
      textarea,
      select,
      small,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        color: inherit;
      }

      a:not(.btn):not(.nav-link):not(.dropdown-item) {
        color: var(--accent);
      }

      a:not(.btn):not(.nav-link):not(.dropdown-item):hover {
        color: var(--accent);
        opacity: .88;
      }

      .app-shell { min-height: 100vh; position: relative; }

      .sidebar {
        width: var(--sidebar-width);
        background:
          linear-gradient(180deg, rgba(15,23,42,.98) 0%, rgba(15,23,42,.92) 100%);
        color: #fff;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        transition: width .25s ease, transform .25s ease;
        border-right: 1px solid rgba(255,255,255,.06);
        backdrop-filter: blur(14px);
      }

      .sidebar .brand {
        padding: 18px 18px 16px;
        border-bottom: 1px solid rgba(255,255,255,.08);
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(45,212,191,.24), rgba(59,130,246,.32));
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        letter-spacing: .04em;
      }

      .brand-copy { min-width: 0; }

      .sidebar-subcopy {
        color: rgba(255,255,255,.55);
      }

      .sidebar .nav-link {
        color: rgba(255,255,255,.78);
        padding: 12px 14px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
        border: 1px solid transparent;
        transition: all .18s ease;
      }

      .sidebar .nav-link:hover {
        background: rgba(255,255,255,.08);
        color: #fff;
        transform: translateX(2px);
      }

      .sidebar .nav-link.active {
        background: linear-gradient(135deg, rgba(45,212,191,.18), rgba(59,130,246,.18));
        color: #fff;
        border: 1px solid rgba(45,212,191,.24);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
      }

      .sidebar .section-title {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(255,255,255,.5);
        padding: 14px 18px 8px;
      }

      .nav-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.05);
        font-size: 16px;
        flex-shrink: 0;
      }

      .content-wrap {
        flex: 1;
        min-width: 0;
        transition: margin-left .25s ease;
      }

      .topbar {
        background: var(--topbar-bg);
        border-bottom: 1px solid var(--topbar-border);
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px);
        color: var(--topbar-text);
      }

      .page-container { padding: 26px; }

      .card-soft {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        box-shadow: var(--shadow-soft);
        border-radius: 24px;
        backdrop-filter: blur(10px);
        color: var(--ink-900);
      }

      .badge-soft-danger { background: rgba(220,53,69,.12); color: #dc3545; }
      .badge-soft-success { background: rgba(25,135,84,.12); color: #198754; }
      .badge-soft-primary { background: var(--accent-soft); color: var(--accent); }
      .view-toggle .btn {
        border-radius: 999px !important;
        padding-inline: 14px;
      }
      .view-toggle .btn.active {
        background: var(--ink-900);
        color: #fff;
        border-color: var(--ink-900);
      }
      .card-preview {
        width: 100%;
        aspect-ratio: 16 / 10;
        max-height: 168px;
        object-fit: cover;
        background: var(--surface-muted);
      }
      .thumb-sm {
        width: 52px;
        height: 52px;
        object-fit: cover;
        border-radius: 14px;
      }
      .thumb-md {
        width: 76px;
        height: 76px;
        object-fit: cover;
        border-radius: 16px;
      }
      .avatar-sm {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        object-fit: cover;
      }
      .avatar-md {
        width: 52px;
        height: 52px;
        border-radius: 999px;
        object-fit: cover;
      }
      .avatar-lg {
        width: 84px;
        height: 84px;
        border-radius: 999px;
        object-fit: cover;
      }

      .btn {
        border-radius: 14px;
        font-weight: 600;
      }

      .btn-dark {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        border-color: #0f172a;
        box-shadow: 0 10px 24px rgba(15,23,42,.14);
      }

      .btn-outline-dark {
        border-color: rgba(15,23,42,.14);
        color: var(--ink-900);
      }

      .form-control, .form-select {
        border-radius: 16px;
        border-color: rgba(148,163,184,.22);
        box-shadow: none;
        background: rgba(255,255,255,.92);
        color: var(--ink-900);
      }

      .form-control:focus, .form-select:focus {
        border-color: rgba(15,118,110,.45);
        box-shadow: 0 0 0 4px rgba(15,118,110,.10);
      }

      .dropdown-menu {
        background: var(--dropdown-bg);
        border: 1px solid var(--panel-border);
        border-radius: 18px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }

      .dropdown-item {
        color: var(--ink-900);
      }

      .dropdown-item:hover {
        background: rgba(15,118,110,.08);
        color: var(--ink-900);
      }

      .dropdown-divider {
        border-color: var(--panel-border);
      }

      .shell-icon-btn {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .mobile-post-menu .dropdown-menu {
        min-width: 220px;
      }

      .notification-trigger {
        position: relative;
      }

      .notification-count-badge {
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ef4444;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        line-height: 1;
      }

      .notification-trigger .notification-count-badge {
        position: absolute;
        top: -6px;
        right: -6px;
      }

      .notification-toast-container {
        z-index: 1085;
        width: min(360px, calc(100vw - 24px));
      }

      .notification-toast {
        background: var(--panel-bg);
        color: var(--ink-900);
        border: 1px solid var(--panel-border) !important;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(12px);
      }

      .notification-toast .toast-header {
        background: transparent;
        color: var(--ink-900);
        border-bottom-color: var(--panel-border);
      }

      .sidebar-profile-panel {
        background: rgba(255,255,255,.06);
        border-color: rgba(255,255,255,.08);
      }

      .sidebar-profile-copy {
        color: rgba(255,255,255,.6);
      }

      .topbar .btn-outline-secondary,
      .topbar .btn-outline-dark {
        border-color: rgba(255,255,255,.16);
        color: var(--topbar-text);
        background: rgba(255,255,255,.04);
      }

      .topbar .btn-outline-secondary:hover,
      .topbar .btn-outline-dark:hover {
        background: rgba(255,255,255,.10);
        color: #fff;
        border-color: rgba(255,255,255,.22);
      }

      .topbar .btn-dark {
        background: rgba(255,255,255,.10);
        border-color: rgba(255,255,255,.14);
        box-shadow: none;
      }

      .topbar .btn-dark:hover {
        background: rgba(255,255,255,.16);
      }

      .topbar .text-muted {
        color: var(--topbar-subtext) !important;
      }

      .theme-toggle-label {
        font-size: 16px;
        line-height: 1;
      }

      body.theme-dark .btn-outline-dark {
        border-color: rgba(148,163,184,.22);
        color: var(--ink-900);
      }

      body.theme-dark .btn-outline-dark:hover {
        background: rgba(148,163,184,.10);
        color: var(--ink-900);
      }

      body.theme-dark .form-control,
      body.theme-dark .form-select {
        background: rgba(15,23,42,.84);
        border-color: rgba(148,163,184,.18);
        color: var(--ink-900);
      }

      body.theme-dark .table {
        color: var(--ink-900);
      }

      body.theme-dark .table thead th {
        color: var(--ink-500);
      }

      body.theme-dark .text-muted {
        color: var(--ink-500) !important;
      }

      body.theme-dark .alert {
        border-color: rgba(148,163,184,.16);
      }

      body.theme-dark .alert-success {
        background: rgba(34,197,94,.12);
        color: #bbf7d0;
      }

      body.theme-dark .alert-danger {
        background: rgba(239,68,68,.12);
        color: #fecaca;
      }

      body.theme-dark .alert-warning {
        background: rgba(245,158,11,.14);
        color: #fde68a;
      }

      body.theme-dark .alert-info {
        background: rgba(59,130,246,.14);
        color: #bfdbfe;
      }

      body.theme-dark .alert-light {
        background: rgba(30,41,59,.92);
        color: var(--ink-900);
      }

      body.theme-dark .bg-light {
        background-color: rgba(15,23,42,.72) !important;
      }

      body.theme-dark .bg-white {
        background-color: rgba(15,23,42,.84) !important;
      }

      body.theme-dark .bg-white.bg-opacity-75,
      body.theme-dark .bg-white[class*="bg-opacity"] {
        background-color: rgba(15,23,42,.78) !important;
      }

      body.theme-dark .border {
        border-color: rgba(148,163,184,.16) !important;
      }

      body.theme-dark .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
      }

      body.theme-dark .form-control::placeholder,
      body.theme-dark .form-select::placeholder {
        color: rgba(148,163,184,.68);
      }

      body.theme-dark .badge-soft-danger {
        background: rgba(239,68,68,.16);
        color: #fca5a5;
      }

      body.theme-dark .badge-soft-success {
        background: rgba(34,197,94,.16);
        color: #86efac;
      }

      body.theme-dark .badge-soft-primary {
        background: rgba(45,212,191,.16);
        color: #99f6e4;
      }

      .stat-card {
        position: relative;
        overflow: hidden;
      }

      .stat-card::after {
        content: "";
        position: absolute;
        inset: auto -20% -45% auto;
        width: 180px;
        height: 180px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(45,212,191,.20), transparent 70%);
        pointer-events: none;
      }

      .table thead th { color: #6b7280; font-weight: 600; font-size: 13px; }
      .table td { vertical-align: middle; }

      body.sidebar-collapsed .sidebar {
        width: var(--sidebar-collapsed-width);
      }

      body.sidebar-collapsed .sidebar .nav-label,
      body.sidebar-collapsed .sidebar .section-title,
      body.sidebar-collapsed .sidebar .brand-copy,
      body.sidebar-collapsed .sidebar .profile-meta {
        display: none !important;
      }

      body.sidebar-collapsed .sidebar .brand {
        justify-content: center !important;
      }

      body.sidebar-collapsed .sidebar .nav-link {
        justify-content: center;
        padding-inline: 10px;
      }

      body.sidebar-collapsed .sidebar .card-soft {
        padding-inline: 10px !important;
      }

      body.sidebar-collapsed .sidebar .d-flex.align-items-center.gap-3 {
        justify-content: center;
      }

      @media (max-width: 992px) {
        .sidebar { position: fixed; left: -270px; transition: left .2s ease; z-index: 50; }
        .sidebar.show { left: 0; }
        body.sidebar-collapsed .sidebar { width: var(--sidebar-width); }
        body.sidebar-collapsed .sidebar .nav-label,
        body.sidebar-collapsed .sidebar .section-title,
        body.sidebar-collapsed .sidebar .brand-copy,
        body.sidebar-collapsed .sidebar .profile-meta {
          display: initial !important;
        }
        .sidebar-backdrop { display:none; }
        .sidebar-backdrop.show {
          display:block;
          position: fixed;
          inset: 0;
          background: rgba(0,0,0,.4);
          z-index: 40;
        }
      }
    </style>
  </head>

  <body data-authenticated="<%= user_signed_in? %>">
    <script>
      function setSidebarState(collapsed) {
        document.body.classList.toggle("sidebar-collapsed", collapsed);
        try { localStorage.setItem("lf_sidebar_collapsed", collapsed ? "1" : "0"); } catch (e) {}
      }

      function setTheme(theme) {
        const dark = theme === "dark";
        document.body.classList.toggle("theme-dark", dark);
        try { localStorage.setItem("lf_theme", dark ? "dark" : "light"); } catch (e) {}
        const label = document.getElementById("themeToggleLabel");
        if (label) label.className = dark ? "bi bi-sun-fill theme-toggle-label" : "bi bi-moon-stars-fill theme-toggle-label";
      }

      function initSidebarState() {
        try {
          const collapsed = localStorage.getItem("lf_sidebar_collapsed") === "1";
          if (window.innerWidth > 992) setSidebarState(collapsed);
        } catch (e) {}
      }

      function initThemeState() {
        try {
          const stored = localStorage.getItem("lf_theme");
          if (stored === "dark" || stored === "light") {
            setTheme(stored);
          } else {
            setTheme(window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          }
        } catch (e) {}
      }

      function toggleTheme() {
        const dark = !document.body.classList.contains("theme-dark");
        setTheme(dark ? "dark" : "light");
      }

      function toggleSidebarDesktop() {
        const collapsed = !document.body.classList.contains("sidebar-collapsed");
        setSidebarState(collapsed);
      }

      function toggleSidebar(){
        const sb = document.getElementById("appSidebar");
        const bd = document.getElementById("sidebarBackdrop");
        if(!sb || !bd) return;
        sb.classList.toggle("show");
        bd.classList.toggle("show");
      }

      document.addEventListener("DOMContentLoaded", function() {
        initThemeState();
        initSidebarState();
      });
    </script>

    <% if user_signed_in? %>
      <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

      <div class="d-flex app-shell">
        <!-- Sidebar -->
        <aside class="sidebar" id="appSidebar">
          <div class="brand d-flex align-items-center justify-content-between gap-3">
            <%= link_to root_path, class: "d-flex align-items-center gap-3 text-decoration-none text-reset" do %>
              <div class="brand-mark">LF</div>
              <div class="brand-copy">
                <div class="fw-bold" style="font-size: 18px;">Lost & Found</div>
                <div class="small sidebar-subcopy">Campus Portal</div>
              </div>
            <% end %>
            <div class='d-none'>
              <button class="btn btn-sm btn-outline-light d-none d-lg-inline-flex" onclick="toggleSidebarDesktop()"><i class="bi bi-layout-sidebar-inset-reverse"></i></button>
              <button class="btn btn-sm btn-outline-light d-lg-none" onclick="toggleSidebar()"><i class="bi bi-x-lg"></i></button>
            </div>
          </div>

          <div class="section-title">Main</div>
          <nav class="px-3 pb-3">
            <a class="nav-link <%= current_page?(root_path) ? 'active' : '' %>" href="<%= root_path %>">
              <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
              <span class="nav-label">Dashboard</span>
            </a>

            <a class="nav-link <%= request.path.start_with?('/items') ? 'active' : '' %>" href="<%= items_path %>">
              <span class="nav-icon"><i class="bi bi-box-seam"></i></span>
              <span class="nav-label">Items</span>
            </a>

            <a class="nav-link <%= request.path.start_with?('/claims') ? 'active' : '' %>" href="<%= claims_path %>">
              <span class="nav-icon"><i class="bi bi-patch-check"></i></span>
              <span class="nav-label">Claims</span>
            </a>

            <a class="nav-link <%= request.path.start_with?('/search') ? 'active' : '' %>" href="<%= search_path %>">
              <span class="nav-icon"><i class="bi bi-search"></i></span>
              <span class="nav-label">Search</span>
            </a>

            <a class="nav-link <%= request.path.start_with?('/notifications') ? 'active' : '' %>" href="<%= notifications_path %>">
              <span class="nav-icon"><i class="bi bi-bell"></i></span>
              <span class="nav-label d-flex align-items-center gap-2">
                Notifications
                <span
                  class="notification-count-badge <%= 'd-none' if unread_notifications_count.zero? %>"
                  data-notification-count
                ><%= unread_notifications_count %></span>
              </span>
            </a>

            <a class="nav-link <%= request.path.start_with?('/conversations') ? 'active' : '' %>" href="<%= conversations_path %>">
              <span class="nav-icon"><i class="bi bi-chat-dots"></i></span>
              <span class="nav-label">Messages</span>
            </a>

            <% if current_user.admin? || current_user.faculty? %>
              <a class="nav-link <%= request.path.start_with?('/staff/claims') ? 'active' : '' %>" href="<%= staff_claims_path %>">
                <span class="nav-icon"><i class="bi bi-qr-code-scan"></i></span>
                <span class="nav-label">Pending Claims</span>
              </a>

              <a class="nav-link <%= request.path.start_with?('/analytics') ? 'active' : '' %>" href="<%= analytics_path %>">
                <span class="nav-icon"><i class="bi bi-bar-chart-line"></i></span>
                <span class="nav-label">Analytics</span>
              </a>
            <% end %>

            <% if current_user.admin? %>
              <div class="section-title mt-2">Admin</div>
              <a class="nav-link" href="/admin">
                <span class="nav-icon"><i class="bi bi-shield-lock"></i></span>
                <span class="nav-label">Admin Panel</span>
              </a>
            <% end %>
          </nav>

          <div class="mt-auto px-3 pb-4">
            <div class="card card-soft p-3 sidebar-profile-panel">
              <div class="d-flex align-items-center gap-3">
                <%= image_tag profile_image_source(current_user), class: "avatar-md border border-light-subtle" %>
                <div class="profile-meta">
                  <div class="small sidebar-profile-copy">Logged in as</div>
                  <div class="small sidebar-profile-copy"><%= current_user.role %></div>
                </div>
              </div>
            </div>
          </div>
        </aside>

        <!-- Main -->
        <main class="content-wrap">
          <!-- Topbar -->
          <div class="topbar">
            <div class="container-fluid">
              <div class="d-flex align-items-center justify-content-between py-3 px-2 px-md-3">
                <div class="d-flex align-items-center gap-2">
                  <button class="btn btn-outline-secondary d-lg-none" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
                  <button class="btn btn-outline-secondary d-none d-lg-inline-flex" onclick="toggleSidebarDesktop()"><i class="bi bi-layout-sidebar-inset"></i></button>
                  <%= link_to root_path, class: "text-decoration-none", style: "color: inherit;" do %>
                    <div class="fw-bold"><%= current_user.campus&.name.presence || "Campus Lost & Found" %></div>
                    <span class='d-none d-sm-inline'>
                      <div class="small text-muted">Lost &amp; found workspace for your campus</div>
                    </span>
                  <% end %>
                </div>

                <div class="d-flex align-items-center gap-2">
                  <button class="btn btn-outline-secondary shell-icon-btn" type="button" onclick="toggleTheme()" title="Toggle dark mode">
                    <i id="themeToggleLabel" class="bi bi-moon-stars-fill theme-toggle-label"></i>
                  </button>
                  <a class="btn btn-outline-secondary shell-icon-btn notification-trigger" href="<%= notifications_path %>" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                    <span
                      class="notification-count-badge <%= 'd-none' if unread_notifications_count.zero? %>"
                      data-notification-count
                    ><%= unread_notifications_count %></span>
                  </a>
                  <div class="dropdown mobile-post-menu d-md-none">
                    <button class="btn btn-outline-dark shell-icon-btn" type="button" data-bs-toggle="dropdown" aria-label="Post item">
                      <i class="bi bi-plus-lg"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2">
                      <%= link_to new_item_path(type: "lost"), class: "dropdown-item rounded-3 py-2" do %>
                        <i class="bi bi-exclamation-circle me-2"></i>Post Lost
                      <% end %>
                      <%= link_to new_item_path(type: "found"), class: "dropdown-item rounded-3 py-2" do %>
                        <i class="bi bi-bag-check me-2"></i>Post Found
                      <% end %>
                    </div>
                  </div>
                  <a class="btn btn-sm btn-outline-dark py-2 d-none d-md-inline-flex" href="<%= new_item_path(type: 'lost') %>">+ Post Lost</a>
                  <a class="btn btn-sm btn-outline-dark py-2 d-none d-md-inline-flex" href="<%= new_item_path(type: 'found') %>">+ Post Found</a>

                  <div class="dropdown">
                    <button class="btn btn-dark shell-icon-btn p-1" type="button" data-bs-toggle="dropdown" aria-label="Open account menu">
                      <%= image_tag profile_image_source(current_user), class: "avatar-sm border border-light-subtle" %>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end">
                      <div class="px-3 py-2">
                        <div class="d-flex align-items-center gap-3">
                          <%= image_tag profile_image_source(current_user), class: "avatar-md border border-light-subtle" %>
                          <div class="small">
                            <div class="fw-semibold text-secondary"><%= current_user.email %></div>
                            <div class="fw-semibold text-secondary"><%= current_user.role.capitalize %></div>
                          </div>
                        </div>
                      </div>
                      <div class="dropdown-divider"></div>
                      <%= link_to "View Profile", profile_path, class: "dropdown-item" %>
                      <%= link_to "Edit Profile", edit_profile_path, class: "dropdown-item" %>
                      <div class="dropdown-divider"></div>
                      <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "dropdown-item" %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Flash -->
          <div class="container-fluid">
            <div class="px-2 px-md-3 pt-3">
              <% flash.each do |type, msg| %>
                <% bs = (type.to_s == "notice") ? "success" : (type.to_s == "alert") ? "danger" : "info" %>
                <div class="alert alert-<%= bs %> alert-dismissible fade show" role="alert">
                  <%= msg %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
              <% end %>
            </div>
          </div>

          <div class="page-container">
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <!-- If not logged in, show clean centered container for Devise screens -->
      <div class="container py-5">
        <% if flash.any? %>
          <div class="mx-auto mb-4" style="max-width: 560px;">
            <% flash.each do |type, msg| %>
              <% bs = (type.to_s == "notice") ? "success" : (type.to_s == "alert") ? "danger" : "info" %>
              <div class="alert alert-<%= bs %> alert-dismissible fade show rounded-4" role="alert">
                <%= msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% end %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
