<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Messages</h4>
    <div class="text-muted small">Item-linked chats with other users.</div>
  </div>
</div>

<% if @conversations.any? %>
  <div class="d-grid gap-3">
    <% @conversations.each do |conversation| %>
      <% other_user = conversation.other_participant(current_user) %>
      <% last_message = conversation.messages.order(created_at: :desc).first %>
      <div class="card card-soft">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
              <div class="fw-bold"><%= conversation.item.title %></div>
              <div class="small text-muted">Chat with <%= other_user.email %></div>
              <div class="small text-muted"><%= conversation.item.campus&.name %> • <%= conversation.item.item_type.capitalize %> item</div>
              <% if last_message.present? %>
                <div class="small text-muted mt-2">
                  Last message: <%= truncate(last_message.body, length: 80) %>
                </div>
              <% end %>
            </div>
            <%= link_to "Open Chat", conversation_path(conversation), class: "btn btn-dark" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card card-soft">
    <div class="card-body p-4 text-muted">
      No conversations yet. Open an item and start a chat from there.
    </div>
  </div>
<% end %>
