<div class="mb-3">
  <h4 class="fw-bold mb-0">Claim Details</h4>
  <div class="text-muted small">Item: <%= @claim.item&.title %></div>
</div>

<div class="row g-3">
  <div class="col-lg-8">
    <div class="card card-soft">
      <div class="card-body p-4">
        <div class="text-muted small mb-1">Proof Note</div>
        <div><%= simple_format(@claim.proof_note) %></div>

        <hr>

        <div class="d-flex flex-wrap gap-2">
          <span class="badge badge-soft-primary px-3 py-2">Status: <%= @claim.status.to_s.capitalize %></span>
          <span class="badge badge-soft-success px-3 py-2">Claim Code: <%= @claim.claim_code.presence || "-" %></span>
          <% if @claim.pickup_verified? %>
            <span class="badge badge-soft-success px-3 py-2">Pickup Verified</span>
          <% end %>
        </div>

        <% if @claim.proof_files.attached? %>
          <hr>
          <div class="text-muted small mb-2">Proof Files</div>
          <div class="d-flex flex-wrap gap-2">
            <% @claim.proof_files.each do |file| %>
              <% if file.content_type&.start_with?("image/") %>
                <%= image_tag file, class: "thumb-md border" %>
              <% else %>
                <%= link_to file.filename.to_s, rails_blob_path(file, disposition: "attachment"),
                  class: "btn btn-sm btn-outline-dark" %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <% if @claim.status == "approved" && !@claim.pickup_verified? %>
          <hr>
          <div class="row g-4 align-items-center">
            <div class="col-lg-5">
              <div class="border rounded-4 p-3 bg-white text-center">
                <%= pickup_qr_svg(@claim) %>
              </div>
            </div>
            <div class="col-lg-7">
              <div class="text-muted small mb-1">Pickup Token</div>
              <div class="fw-bold fs-5 mb-2"><%= @claim.display_pickup_token %></div>
              <div class="small text-muted">
                Show this QR code or token to staff/admin at pickup. Your item will only be marked as returned after verification.
              </div>
            </div>
          </div>
        <% elsif @claim.pickup_verified? %>
          <hr>
          <div class="alert alert-success rounded-4 mb-0">
            Pickup was verified on <strong><%= @claim.pickup_verified_at.strftime("%d %b %Y, %I:%M %p") %></strong>.
          </div>
        <% elsif @claim.status == "rejected" && @claim.rejection_reason.present? %>
          <hr>
          <div class="alert alert-danger rounded-4 mb-0">
            This claim was rejected. Reason: <strong><%= @claim.rejection_reason %></strong>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card card-soft">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-1">Process</h6>
        <div class="small text-muted">
          Admin/finder reviews your claim request. If approved, you can contact the faculty to collect the item.
        </div>
        <hr>
        <%= link_to "Browse Items", items_path, class: "btn btn-outline-dark w-100" %>
      </div>
    </div>
  </div>
</div>
