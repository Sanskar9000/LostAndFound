<div class="d-flex flex-wrap gap-2">
  <%= link_to "Pending",
    claims_path(query_params_with_status("pending")),
    class: "btn btn-sm #{current_status == 'pending' ? 'btn-dark' : 'btn-outline-dark'}" %>
  <%= link_to "Approved",
    claims_path(query_params_with_status("approved")),
    class: "btn btn-sm #{current_status == 'approved' ? 'btn-dark' : 'btn-outline-dark'}" %>
  <%= link_to "Rejected",
    claims_path(query_params_with_status("rejected")),
    class: "btn btn-sm #{current_status == 'rejected' ? 'btn-dark' : 'btn-outline-dark'}" %>
</div>
