<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
  <div>
    <h4 class="fw-bold mb-0">Claims</h4>
    <div class="text-muted small">Track your submitted claims</div>
    <div class="mt-3">
      <%= render "status_tabs", current_status: @current_status %>
    </div>
  </div>

  <%= render "view_toggle" %>
</div>

<div class="card card-soft">
  <div class="card-body">
    <% if @claims.present? %>
      <% if index_view_mode == "list" %>
        <%= render "list", claims: @claims %>
      <% else %>
        <%= render "grid", claims: @claims %>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-5">No claims submitted yet.</div>
    <% end %>
  </div>
</div>
