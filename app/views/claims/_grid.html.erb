<div class="row g-3">
  <% claims.each do |claim| %>
    <div class="col-sm-6 col-xl-4">
      <div class="card card-soft h-100 overflow-hidden">
        <%= image_tag claim_preview_source(claim), class: "card-preview border-bottom" %>
        <div class="card-body p-4 d-flex flex-column">
          <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
            <h6 class="fw-bold mb-0"><%= claim.item&.title %></h6>
            <% if claim.status == "approved" %>
              <span class="badge badge-soft-success">Approved</span>
            <% elsif claim.status == "rejected" %>
              <span class="badge badge-soft-danger">Rejected</span>
            <% else %>
              <span class="badge badge-soft-primary">Pending</span>
            <% end %>
          </div>

          <div class="small text-muted mb-1">Claimed by: <span class="text-muted fw-semibold"><%= claim.user&.email %></span></div>
          <div class="small text-muted mb-1">Claim code: <span class="text-muted fw-semibold"><%= claim.claim_code.presence || "-" %></span></div>
          <div class="small text-muted mb-3">Submitted: <span class="text-muted fw-semibold"><%= claim.created_at.strftime("%d %b %Y") %></span></div>

          <div class="text-muted small mb-3"><%= truncate(claim.proof_note.to_s, length: 100) %></div>

          <div class="mt-auto">
            <%= link_to "View", claim_path(claim), class: "btn btn-sm btn-dark w-100" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
