<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Pending Claims</h4>
    <div class="text-muted small">Review claims, approve pickup, and verify collection.</div>
  </div>

  <%= render "view_toggle" %>
</div>

<div class="mb-3 d-flex flex-wrap gap-2">
  <%= link_to "Pending Review", staff_claims_path(status: "pending", view: index_view_mode), class: "btn btn-sm #{@current_status == 'pending' ? 'btn-dark' : 'btn-outline-dark'}" %>
  <%= link_to "Approved / Awaiting Pickup", staff_claims_path(status: "approved", view: index_view_mode), class: "btn btn-sm #{@current_status == 'approved' ? 'btn-dark' : 'btn-outline-dark'}" %>
  <%= link_to "Pickup Verified", staff_claims_path(status: "picked_up", view: index_view_mode), class: "btn btn-sm #{@current_status == 'picked_up' ? 'btn-dark' : 'btn-outline-dark'}" %>
</div>

<div class="card card-soft">
  <div class="card-body">
    <% if @claims.present? %>
      <% if index_view_mode == "list" %>
        <%= render "list", claims: @claims %>
      <% else %>
        <%= render "grid", claims: @claims %>
      <% end %>
    <% else %>
      <div class="text-center text-muted py-5">No pending claims.</div>
    <% end %>
  </div>
</div>
